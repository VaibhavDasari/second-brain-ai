// Prisma schema for Second Brain — Neon PostgreSQL
// Run: npx prisma generate && npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon requires directUrl for migrations
  directUrl = env("DATABASE_URL")
}

model KnowledgeItem {
  id        String   @id @default(cuid())
  title     String
  content   String
  type      String   // "note" | "link" | "insight"
  sourceUrl String?
  tags      String[]
  summary   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([createdAt])
  @@map("knowledge_items")
}
